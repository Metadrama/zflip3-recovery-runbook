#!/system/bin/sh
# Systemless Antigravity CLI wrapper - alias for 'agy'
# This script is overlaid onto /system/bin/antigravity by the gemini-cli Magisk module.
# It delegates to the same auto-patching VA39 wrapper as /system/bin/agy.

WRAPPER="/data/data/com.termux/files/home/.local/bin/agy-va39"

export HOME="${HOME:-/data/ssh/root}"
export PATH="/data/data/com.termux/files/usr/bin:$PATH"

if [ -x "$WRAPPER" ]; then
  exec "$WRAPPER" "$@"
else
  echo "antigravity: auto-patching wrapper not found at $WRAPPER"
  echo "Run the setup from the zflip3-recovery-runbook first."
  exit 1
fi
