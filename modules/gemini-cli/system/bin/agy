#!/system/bin/sh
export PATH="/data/data/com.termux/files/usr/bin:$PATH"
export LD_LIBRARY_PATH="/data/data/com.termux/files/usr/lib"
export HOME="/data/ssh/root"
export TERMUX_VERSION="0.118"

if [ -x /data/data/com.termux/files/usr/bin/agy ]; then
  exec /data/data/com.termux/files/usr/bin/agy "$@"
elif [ -x /data/ssh/root/bin/agy ]; then
  exec /data/ssh/root/bin/agy "$@"
elif [ -f /data/data/com.termux/files/usr/bin/antigravity ]; then
  exec node /data/data/com.termux/files/usr/bin/antigravity "$@"
else
  echo "agy/antigravity CLI not installed yet."
  exit 1
fi
