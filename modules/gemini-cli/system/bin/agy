#!/system/bin/sh
# Systemless Antigravity CLI wrapper - auto-patching native binary support
# This script is overlaid onto /system/bin/agy by the gemini-cli Magisk module.
# It routes execution through the Termux-based VA39 auto-patching wrapper,
# which handles glibc loading, TCMalloc patching, and seccomp workarounds.

WRAPPER="/data/data/com.termux/files/home/.local/bin/agy-va39"

export HOME="${HOME:-/data/ssh/root}"
export PATH="/data/data/com.termux/files/usr/bin:$PATH"

if [ -x "$WRAPPER" ]; then
  exec "$WRAPPER" "$@"
else
  echo "agy: auto-patching wrapper not found at $WRAPPER"
  echo "Run the setup from the zflip3-recovery-runbook first."
  exit 1
fi
